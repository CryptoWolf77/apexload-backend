ENVIRONMENT=development
API_KEY=change-me-later
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080
USE_MOCK_ANALYZE_FALLBACK=true
INSTAGRAM_AUTH_MODE=cookiefile
INSTAGRAM_COOKIES_PATH=data/cookies/instagram_cookies.txt
INSTAGRAM_COOKIE_FILE=data/cookies/instagram_cookies.txt
INSTAGRAM_HEALTHCHECK_URL=
INSTAGRAM_COOKIE_HEALTH_ENABLED=true
INSTAGRAM_COOKIE_CHECK_INTERVAL_MINUTES=180
INSTAGRAM_COOKIE_ALERT_COOLDOWN_HOURS=12
INSTAGRAM_SAFETY_MODE_ENABLED=true
INSTAGRAM_SAFETY_STATE_PATH=data/cookies/instagram_safety_state.json
INSTAGRAM_MAX_CONCURRENT_JOBS=1
INSTAGRAM_MAX_REQUESTS_PER_MINUTE=3
INSTAGRAM_MAX_REQUESTS_PER_HOUR=60
INSTAGRAM_FAILURE_THRESHOLD=3
INSTAGRAM_RESTRICTION_COOLDOWN_HOURS=72
INSTAGRAM_RATE_LIMIT_COOLDOWN_HOURS=24
INSTAGRAM_UNKNOWN_ERROR_COOLDOWN_MINUTES=30
INSTAGRAM_RECOVERY_SUCCESS_THRESHOLD=2
YTDLP_COOKIES_FROM_BROWSER_ENABLE=false
YTDLP_COOKIES_BROWSER=chrome
YTDLP_COOKIES_BROWSER_PROFILE=
YTDLP_COOKIES_BROWSER_KEYRING=
ADMIN_API_KEY=
ADMIN_API_TOKEN=
ADMIN_ALERT_EMAIL=yhadrami2003@gmail.com
ADMIN_PANEL_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ApexLoad Backend
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Public legal-report endpoint. Do not put any secrets in the website build.
LEGAL_NOTIFICATION_EMAIL=copyright@apexload.org
LEGAL_FROM_EMAIL=ApexLoad Legal <legal@apexload.org>
LEGAL_ALLOWED_ORIGINS=https://apexload.org,https://www.apexload.org
LEGAL_TRUSTED_PROXY_CIDRS=
LEGAL_MAX_REQUEST_BYTES=65536
LEGAL_RATE_LIMIT_HOURLY=5
LEGAL_RATE_LIMIT_DAILY=15
LEGAL_DUPLICATE_WINDOW_SECONDS=86400
LEGAL_PENDING_WINDOW_SECONDS=300
LEGAL_MIN_FORM_SECONDS=3
LEGAL_CLOCK_SKEW_SECONDS=300
LEGAL_EMAIL_TIMEOUT_SECONDS=20
# Set a long random value in Coolify. It salts short-lived rate-limit and
# duplicate fingerprints; it is never exposed to the browser.
LEGAL_FINGERPRINT_SECRET=
YTDLP_UPDATE_POLICY=manual
FFMPEG_LOCATION=
YOUTUBE_AUTH_MODE=none
YOUTUBE_COOKIES_FILE=secrets/youtube_cookies.txt

# Legacy alias kept only for older deployments. Prefer YOUTUBE_AUTH_MODE.
ENABLE_YOUTUBE_COOKIES=false

# Legacy aliases kept only for older deployments. Prefer INSTAGRAM_AUTH_MODE
# and INSTAGRAM_COOKIE_FILE.
ENABLE_INSTAGRAM_COOKIES=false
INSTAGRAM_COOKIES_FILE=
